generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id                 String    @id @default(cuid())
  nombre             String?
  empresa            String?
  email              String?
  rubro              String?
  empleados          String?
  codigoPais         String?
  telefono           String?
  telefonoCompleto   String?
  facturacionAnual   String?
  problema           String
  objetivo           String
  diagnostico        String
  diagnosticoResumen String?
  leadScore          Int       @default(0)
  leadLevel          String    @default("Frío")
  emailStatus        String?
  emailError         String?
  aceptaTerminos     Boolean   @default(false)
  fechaAceptacion    DateTime?
  humanVerified      Boolean   @default(false)
  isUnlocked         Boolean   @default(false)
  unlockedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  estadoComercial    String    @default("Nuevo")
  notasInternas      String?
}

model rrhh_processes {
  id         String   @id
  tenant_id  String
  user_id    String
  input      Json
  output     Json?
  created_at DateTime
  updated_at DateTime
}