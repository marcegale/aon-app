generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String   @id @default(cuid())
  nombre      String
  empresa     String
  email       String
  rubro       String?
  empleados   String?
  problema    String
  objetivo    String
  diagnostico String
  leadScore   Int
  leadLevel   String
  emailStatus String?
  emailError  String?
  aceptaTerminos  Boolean  @default(false)
  fechaAceptacion DateTime?
  createdAt   DateTime @default(now())
}