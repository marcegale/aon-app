generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id                 String    @id @default(cuid())
  nombre             String?
  empresa            String?
  email              String?
  rubro              String?
  empleados          String?
  codigoPais         String?
  telefono           String?
  telefonoCompleto   String?
  facturacionAnual   String?
  problema           String
  objetivo           String
  diagnostico        String
  diagnosticoResumen String?
  leadScore          Int       @default(0)
  leadLevel          String    @default("Frío")
  emailStatus        String?
  emailError         String?
  aceptaTerminos     Boolean   @default(false)
  fechaAceptacion    DateTime?
  humanVerified      Boolean   @default(false)
  isUnlocked         Boolean   @default(false)
  unlockedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  estadoComercial    String    @default("Nuevo")
  notasInternas      String?
}

model rrhh_processes {
  id         String   @id
  tenant_id  String
  user_id    String
  input      Json
  output     Json?
  created_at DateTime
  updated_at DateTime
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents TenantDocument[]
  analyses  TenantAnalysis[]
}

model TenantDocument {
  id          String   @id @default(cuid())
  tenantId    String
    tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    String
  title       String
  description String
  status      String
  source      String
  fileUrl     String?
  fileName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("tenant_documents")
}

model TenantAnalysis {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode          String
  summary       String
  risks         String[]
  opportunities String[]
  priority      String?
  globalScore   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("tenant_analyses")
  rawData Json?
}